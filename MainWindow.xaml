<Window x:Class="CyberSecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        x:Name="MainWindowUI"
        Title="Cybersecurity Awareness Bot"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="#0B0F19">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="137*"/>
            <RowDefinition Height="567*"/>
        </Grid.RowDefinitions>

        <!-- the MAIN LAYOUT -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- This is my SIDEBAR -->
        <Border x:Name="SidebarPanel"
        Background="#111827"
        BorderBrush="#3B82F6"
        BorderThickness="0,0,1.5,0" Grid.RowSpan="2">

       <Border.Effect>
       <DropShadowEffect
        Color="#2563EB"
        BlurRadius="25"
        ShadowDepth="0"
        Opacity="0.55"/>
      </Border.Effect>

        <StackPanel Margin="20">
        <Image Source="/Assets/Icon.png"
       Width="127"
       Height="124"
       Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="1" ScaleX="0.999"/>
                            <SkewTransform AngleY="-2.088" AngleX="1.726"/>
                            <RotateTransform Angle="2.098"/>
                            <TranslateTransform Y="-0.87" X="-10.925"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <TextBlock Text="CYBER BOT"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           RenderTransformOrigin="0.487,198.621" Height="51" Width="197">
                    <TextBlock.Effect>
       <DropShadowEffect
        Color="#3B82F6"
        BlurRadius="20"
        ShadowDepth="0"
        Opacity="1"/>
                    </TextBlock.Effect>
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="-0.225"/>
                            <RotateTransform/>
                            <TranslateTransform X="-0.079"/>
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>


                <!-- TOPICS of the thingf -->
                <Border 
                        x:Name="PasswordCard"
                        Background="#1F2937"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,12">

                    <StackPanel>
                        <TextBlock Text="PASSWORD SAFETY"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Use a strong Password ;)"
                                   Foreground="#9CA3AF"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border 
                    x:Name="PhishingCard"
                    Background="#1F2937"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,12" Height="63" Width="192">

                    <StackPanel>
                        <TextBlock Text="PHISHING"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Avoid Opening sketchy emails. "                           
                                   Foreground="#9CA3AF"
                                   FontSize="12" Height="29" Width="169"/>
                    </StackPanel>
                </Border>

                <Border 
                    x:Name="PrivacyCard"
                    Background="#1F2937"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,12">

                    <StackPanel>
                        <TextBlock Text="PRIVACY"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Use Virtual Cards to transact :D"
                                   Foreground="#9CA3AF"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
                <!-- GIF CIRCLES i think all 3 -->
                <StackPanel Margin="0,0,0,30"

            HorizontalAlignment="Center">

                    <!-- CIRCLE 1 -->
                    <Border Width="90"
        Height="90"
        CornerRadius="45"
        MouseLeftButtonDown="Friday_Click"
Cursor="Hand"                    
        Margin="0,0,0,15"
        BorderBrush="#374151"
        BorderThickness="2"
        Background="#1F2937"
        RenderTransformOrigin="0.5,0.5">

                        <!-- Increasing ANIMATION -->
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="scaleTransform1"
                        ScaleX="1"
                        ScaleY="1"/>
                        </Border.RenderTransform>

                        <!-- HOVER EFFECT -->
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">

                                <Style.Triggers>

                                    <!-- MOUSE HOVER -->
                                    <Trigger Property="IsMouseOver"
                         Value="True">

                                        <Trigger.EnterActions>

                                            <BeginStoryboard>

                                                <Storyboard>

                                                    <!-- expansion effect -->
                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1.18"
                                    Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1.18"
                                    Duration="0:0:0.2"/>

                                                </Storyboard>

                                            </BeginStoryboard>

                                        </Trigger.EnterActions>

                                        <!-- dEcrease -->
                                        <Trigger.ExitActions>

                                            <BeginStoryboard>

                                                <Storyboard>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1"
                                    Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1"
                                    Duration="0:0:0.2"/>

                                                </Storyboard>

                                            </BeginStoryboard>

                                        </Trigger.ExitActions>

                                    </Trigger>

                                </Style.Triggers>

                            </Style>
                        </Border.Style>

                        <!-- GIF -->
                        <Grid>

                            <Ellipse Fill="#1F2937"/>

                            <Image Source="/Assets/friday.gif"
               Stretch="UniformToFill"
               Margin="-36,-3,-25,-2">

                                <Image.Clip>
                                    <EllipseGeometry Center="79,46"
                                 RadiusX="45"
                                 RadiusY="45"/>
                                </Image.Clip>

                            </Image>

                        </Grid>

                    </Border>



                    <!-- CIRCLE 2 -->
                    <Border Width="89"
        Height="89"
        CornerRadius="45"
        MouseLeftButtonDown="Jarvis_Click"
Cursor="Hand"
        Margin="0,0,0,15"
        BorderBrush="#374151"
        BorderThickness="2"
        Background="#1F2937"
        RenderTransformOrigin="0.5,0.5">

                        <!-- SCALE ANIMATION -->
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1"
                        ScaleY="1"/>
                        </Border.RenderTransform>

                        <!-- HOVER EFFECT -->
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">

                                <Style.Triggers>

                                    <Trigger Property="IsMouseOver"
                         Value="True">

                                        <Trigger.EnterActions>

                                            <BeginStoryboard>

                                                <Storyboard>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1.18"
                                    Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1.18"
                                    Duration="0:0:0.2"/>

                                                </Storyboard>

                                            </BeginStoryboard>

                                        </Trigger.EnterActions>

                                        <Trigger.ExitActions>

                                            <BeginStoryboard>

                                                <Storyboard>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1"
                                    Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1"
                                    Duration="0:0:0.2"/>

                                                </Storyboard>

                                            </BeginStoryboard>

                                        </Trigger.ExitActions>

                                    </Trigger>

                                </Style.Triggers>

                            </Style>
                        </Border.Style>

                        <!-- GIF -->
                        <Grid>

                            <Ellipse Fill="#1F2937"/>

                            <Image Source="Assets/Jarvis.gif"
               Stretch="UniformToFill"
               Margin="-38,-2,-25,-6" RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform AngleX="0.955"/>
                                        <RotateTransform/>
                                        <TranslateTransform X="0.783"/>
                                    </TransformGroup>
                                </Image.RenderTransform>

                                <Image.Clip>
                                    <EllipseGeometry Center="80,45"
                                 RadiusX="45"
                                 RadiusY="45"/>
                                </Image.Clip>

                            </Image>

                        </Grid>

                    </Border>

                    <!-- CIRCLE 3 -->
                    <Border Width="90"
        Height="90"
                            MouseLeftButtonDown="Ultron_Click"
Cursor="Hand"
        CornerRadius="45"
        BorderBrush="#374151"
        BorderThickness="2"
        Background="#1F2937"
        RenderTransformOrigin="0.5,0.5">

                        <!--increasing ANIMATION -->
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1"
                        ScaleY="1"/>
                        </Border.RenderTransform>

                        <!-- HOVER EFFECT -->
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">

                                <Style.Triggers>

                                    <Trigger Property="IsMouseOver"
                         Value="True">

                                        <Trigger.EnterActions>

                                            <BeginStoryboard>

                                                <Storyboard>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1.18"
                                    Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1.18"
                                    Duration="0:0:0.2"/>

                                                </Storyboard>

                                            </BeginStoryboard>

                                        </Trigger.EnterActions>

                                        <Trigger.ExitActions>

                                            <BeginStoryboard>

                                                <Storyboard>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1"
                                    Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1"
                                    Duration="0:0:0.2"/>

                                                </Storyboard>

                                            </BeginStoryboard>

                                        </Trigger.ExitActions>

                                    </Trigger>

                                </Style.Triggers>

                            </Style>
                        </Border.Style>

                        <!-- GIF -->
                        <Grid>

                            <Ellipse Fill="#1F2937"/>

                            <Image Source="Assets/Ultron.gif"
               Stretch="UniformToFill"
               Margin="-48,-3,-6,-4">

                                <Image.Clip>
                                    <EllipseGeometry Center="90.9,46"
                                 RadiusX="45"
                                 RadiusY="45"/>
                                </Image.Clip>

                            </Image>

                        </Grid>

                    </Border>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- CHAT SECTION -->
        <Grid Grid.Column="1" Grid.RowSpan="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            
            
            <Border x:Name="TopHeader"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="0,0,0,1">

                <Grid Margin="254,0">

                    <TextBlock Text="CYBERSECURITY AWARENESS ASSISTANT"
                               Foreground="DimGray"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,-126,0"/>

                </Grid>
            </Border>

           
            <Border x:Name="ChatPanel"
        Grid.Row="1"
        Background="#22000000"
        CornerRadius="20"
        Margin="20"
                    BorderBrush="#3B82F6"
BorderThickness="1.5"
        Padding="20">
                <Border.Effect>
                    <DropShadowEffect
        Color="#2563EB"
        BlurRadius="30"
        ShadowDepth="0"
        Opacity="0.45"/>
                </Border.Effect>

                <Grid>

                    <!-- GIF AS THE BACKGROUND( FULL) -->
                    <Image x:Name="ChatBackground"
       Stretch="UniformToFill"
       Opacity="0.35"
       gif:ImageBehavior.AnimatedSource="{Binding}"/>

                    <!-- DARK OVERLAY -->
                    <Rectangle Fill="Black"
                               RadiusX="20"
                               RadiusY="20"
           Opacity="0.18"/>

                    <!-- CHAT -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <StackPanel x:Name="ChatMessages"
                                    Margin="10"/>





                    </ScrollViewer>
                    

                </Grid>
            </Border>

            <!-- INPUT AREA -->
            <Grid Grid.Row="2"
                  Margin="20">

                <Border x:Name="InputPanel"
                        Background="#111827"
                        CornerRadius="20"
                        BorderBrush="#3B82F6"
BorderThickness="1.3"
                        Padding="12" Margin="0,-22,0,0">
                    <Border.Effect>
                        <DropShadowEffect
        Color="#2563EB"
        BlurRadius="20"
        ShadowDepth="0"
        Opacity="0.40"/>
                    </Border.Effect>
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        
                        <TextBox x:Name="UserInput"
         KeyDown="UserInput_KeyDown"
         Background="#1F2937"
         BorderBrush="#374151"
         BorderThickness="1"
         Foreground="White"
         FontSize="16"
         VerticalContentAlignment="Center"
         CaretBrush="White"
         Padding="12"
         Margin="5"
         Height="45"/>

                       
                        <Button x:Name="SendBtn"
                                Grid.Column="1"                             
                                Click="SendButton_Click"
                                Width="43"
                                Height="43"
                                FontSize="18"
                                FontWeight="Bold"
                                Content="➜"
                                Cursor="Hand"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform AngleX="0.331"/>
                                    <RotateTransform/>
                                    <TranslateTransform X="0.144"/>
                                </TransformGroup>
                            </Button.RenderTransform>

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="25">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                    </Grid>
                </Border>

            </Grid>

        </Grid>

    </Grid>
</Window>